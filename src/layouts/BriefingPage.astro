---
import Layout from './Layout.astro';
import Calendar from '../components/Calendar.astro';
import Briefing from '../components/Briefing.astro';
import BriefingNav from '../components/BriefingNav.astro';
import type { Briefing as BriefingType } from '../lib/briefings';
import { formatShort } from '../lib/briefings';

interface Props {
  current: BriefingType;
  prev: BriefingType | null;
  next: BriefingType | null;
}

const { current, prev, next } = Astro.props;
---

<Layout title={`${formatShort(current)} — Morning Brief`} description={current.topStory}>
  <Calendar current={current} prev={prev} next={next} />
  <Briefing briefing={current} />
  <BriefingNav prev={prev} next={next} />
</Layout>
